# LAN: strip AAAA (router ipv6_service already disabled; stop Happy Eyeballs on polluted/useless AAAA)
filter-AAAA

# Firstrade: pin clean IPv4; local= stops upstream AAAA pollution
# IPs calibrated 2026-07-23 via 1.1.1.1 DoH (CF/Vercel may rotate — recheck if App breaks)
local=/firstrade.com/
local=/firstrade.net/
address=/www.firstrade.com/76.76.21.93
address=/api3x.firstrade.com/54.230.70.76
address=/invest.firstrade.com/54.230.70.83
address=/streamingx.firstrade.com/18.65.14.45
address=/rec.firstrade.net/13.226.69.45

